{
  "name": "hamid aluminuim",
  "version": "1.0.0",
  "description": "A professional e-commerce website with modern design and functionality",
  "main": "server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "nodemon backend/server.js",
    "dev:frontend": "live-server frontend --port=3000",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "webpack --mode=production",
    "build:backend": "echo 'Backend build complete'",
    "test": "jest",
    "lint": "eslint . --ext .js,.html,.css",
    "format": "prettier --write ."
  },
  "keywords": [
    "ecommerce",
    "shopping",
    "website",
    "professional",
    "modern"
  ],
  "author": "Oussama",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.1.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "nodemailer": "^6.9.4",
    "stripe": "^13.5.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "eslint": "^8.47.0",
    "jest": "^29.6.2",
    "live-server": "^1.2.2",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.2",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}
